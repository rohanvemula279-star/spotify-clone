# =============================================================
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; THIS example file is NOT — so keep only
# placeholders here, never real secrets.
# NONE of the secret values below use the NEXT_PUBLIC_ prefix, so
# they stay server-only and never reach the browser bundle.
# =============================================================

# --- Spotify Web API (Client Credentials flow) ---------------
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# --- YouTube Data API v3 -------------------------------------
# Enable "YouTube Data API v3" in Google Cloud Console and make a key.
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# --- Supabase -------------------------------------------------
# URL = the BASE project url, NOT the /rest/v1/ endpoint.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# SERVICE ROLE key (Project Settings -> API -> service_role). It bypasses
# RLS and must stay server-side ONLY. This is NOT the anon/publishable key.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
